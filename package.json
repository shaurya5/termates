{
  "name": "termates",
  "version": "1.0.0",
  "description": "On-device terminal multiplexer with persistent sessions, workspaces, and agent linking",
  "type": "module",
  "main": "electron/main.cjs",
  "bin": {
    "termates": "./bin/termates.js"
  },
  "scripts": {
    "build": "esbuild src/client/main.js --bundle --outfile=public/dist/bundle.js --format=iife --platform=browser --target=es2020 --minify",
    "build:dev": "esbuild src/client/main.js --bundle --outfile=public/dist/bundle.js --format=iife --platform=browser --target=es2020 --sourcemap",
    "start": "npm run build && electron .",
    "start:server": "npm run build && node server/index.js",
    "dev": "npm run build:dev && electron .",
    "dev:server": "npm run build:dev && node server/index.js",
    "dist": "npm run build && electron-builder",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:linux": "npm run build && electron-builder --linux",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:perf": "vitest run tests/perf"
  },
  "build": {
    "appId": "com.termates.app",
    "productName": "Termates",
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "build/icon.icns",
      "target": [
        "dmg",
        "zip"
      ],
      "darkModeSupport": true
    },
    "linux": {
      "category": "Development",
      "icon": "build/icon.png",
      "target": [
        "AppImage",
        "deb"
      ]
    },
    "files": [
      "electron/**/*",
      "server/**/*",
      "public/**/*",
      "bin/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "extraResources": [],
    "asar": false
  },
  "dependencies": {
    "commander": "^13.1.0",
    "express": "^4.21.2",
    "node-pty": "^1.2.0-beta.12",
    "ws": "^8.18.0",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0",
    "xterm-addon-web-links": "^0.9.0",
    "xterm-addon-webgl": "^0.16.0"
  },
  "devDependencies": {
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.25.0",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "private": true,
  "license": "MIT"
}
