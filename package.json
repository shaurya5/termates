{
  "name": "termates",
  "version": "1.0.0",
  "description": "On-device terminal multiplexer with agent linking and browser support",
  "type": "module",
  "main": "server/index.js",
  "bin": {
    "termates": "./bin/termates.js"
  },
  "scripts": {
    "build": "esbuild src/client/main.js --bundle --outfile=public/dist/bundle.js --format=iife --platform=browser --target=es2020 --minify",
    "build:dev": "esbuild src/client/main.js --bundle --outfile=public/dist/bundle.js --format=iife --platform=browser --target=es2020 --sourcemap",
    "start": "npm run build && node server/index.js",
    "dev": "npm run build:dev && node server/index.js"
  },
  "dependencies": {
    "commander": "^13.1.0",
    "express": "^4.21.2",
    "node-pty": "^1.2.0-beta.12",
    "ws": "^8.18.0",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0",
    "xterm-addon-web-links": "^0.9.0"
  },
  "devDependencies": {
    "esbuild": "^0.25.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "private": true,
  "license": "MIT"
}
